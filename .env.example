# =============================================================
# LETUS — Phase 0 Environment Variables
# Copy this to services/user/.env and fill in real values.
# NEVER commit .env to git.
# =============================================================

# ---- User Service -------------------------------------------
DATABASE_URL=postgresql://letus:localpassword@localhost:5432/letus_dev

# Generate with: openssl rand -base64 32
# MUST be at least 32 characters. Server refuses to start if missing.
JWT_SECRET=replace_this_with_32_plus_char_random_string
REFRESH_SECRET=replace_this_with_different_32_plus_char_string

PORT=3000
NODE_ENV=development

# ---- CORS (comma-separated, no spaces) ----------------------
# Dev: mobile runs on 8081, backend on 3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,exp://localhost:8081

# ---- DB Pool (tuned for t3.micro, 1 service) ----------------
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000

# ---- Rate Limiting ------------------------------------------
# 20 auth attempts per 15 minutes per IP (applies to /login and /register)
RATE_LIMIT_MAX=20

# ---- Mobile (apps/mobile/.env) ------------------------------
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_GOOGLE_MAPS_KEY=get_from_google_cloud_console

# ---- GitHub Actions Secrets (set in GitHub, not here) -------
# EC2_HOST      → your EC2 public IP
# EC2_SSH_KEY   → private key contents for ubuntu@EC2_HOST
# EXPO_TOKEN    → from expo.dev account settings

# ---- Phase 1 adds -------------------------------------------
# REDIS_URL=redis://localhost:6379

# ---- Phase 2 adds -------------------------------------------
# NEO4J_URI=bolt://localhost:7687
# AWS_S3_BUCKET=letus-media-prod
# CLOUDFRONT_URL=https://cdn.letus.app
