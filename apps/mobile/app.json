{
  "expo": {
    "newArchEnabled": true,
    "name": "Letus",
    "slug": "letus",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A5F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.letus.app",
      "config": {
        "googleMapsApiKey": ""
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E3A5F"
      },
      "package": "com.letus.app",
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Letus needs your location to show what's vibing near you."
        }
      ]
    ],
    "scheme": "letus",
    "experiments": {
      "typedRoutes": true
    },
    "sdkVersion": "52.0.0",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "f1d1e3f3-bd73-4f90-b8ba-1486a2e415fb"
      }
    }
  }
}
